{
    "script_path": {
        "alternative": [
            "@root_path.joinpath('wip.src.infobim.check')",
            "@script_path.move(['..', 'infobim']).joinpath('check')"
        ]
    },
    "config": {
        "engines": [
            "venv",
            "colab"
        ]
    },
    "base": {
        "infra": [
            "is_connected_to_internet",
            "is_root_absolute_path_configured",
            "is_engine_installed",
            "install_python_dependencies"
        ],
        "infobim": [
            "@script_path.get('is_infobim_set')",
            "@script_path.get('install_python_dependencies')"
        ]
    },
    "engine": {
        "venv": {
            "infra": [
                "is_venv_active"
            ]
        },
        "colab": {
            "infra": [
                "is_colab"
            ]
        }
    }
}
